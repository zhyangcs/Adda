# Adda Environment Configuration
# Copy this file to .env and fill in your values
# Reference: https://github.com/langgenius/dify

# ---- LLM API ----
# Required: Your API key for the LLM service
OPENAI_API_KEY=sk-your-api-key-here
# API base URL (DeepSeek, OpenAI, or compatible)
OPENAI_BASE_URL=https://api.deepseek.com/v1
# Default model name
DEFAULT_MODEL=deepseek-chat

# ---- RAG Model ----
# HuggingFace model ID for retrieval-augmented generation
# Uses Qwen2-0.5B by default; set to a local path to skip download
RAG_MODEL_ID=Qwen/Qwen2-0.5B-Instruct

# ---- PostgreSQL ----
PG_USER=myuser
PG_PASSWORD=addapass
PG_DB=mydb
PG_HOST=adda-db
PG_PORT=5432

# ---- App ----
PROJ_PATH=/adda
