from sklearn.preprocessing import StandardScaler

# Standardize the relevant features
scaler = StandardScaler()
df[['std_glucose', 'std_sysbp', 'std_bmi', 'std_totchol']] = scaler.fit_transform(df[['glucose', 'sysbp', 'bmi', 'totchol']])

# Define the function to calculate weighted health index
def calculate_weighted_health_index(row):
    weighted_health_index = (
        (1.5 * row['std_glucose'] * (1 - row['currentsmoker'])) +
        (0.5 * row['std_sysbp'] * row['diabetes']) -
        (0.3 * row['std_bmi'] * row['prevalenthyp']) +
        row['std_totchol']
    ) / row['heartrate']
    return weighted_health_index

# Apply the function to compute the new feature
df['weighted_health_index'] = df.apply(calculate_weighted_health_index, axis=1), 
