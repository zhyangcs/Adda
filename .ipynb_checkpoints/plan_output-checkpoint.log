# Import necessary libraries
import pandas as pd

# Filter for male smokers who smoke more than 5 cigarettes per day
male_smoker_condition = (df['gender'] == 1) & (df['cigsperday'] > 5)

# Compute the sum of totchol and bmi for these patients
df.loc[male_smoker_condition, 'totchol_bmi_sum'] = df.loc[male_smoker_condition, 'totchol'] + df.loc[male_smoker_condition, 'bmi']

# Normalize the sum using Min-Max normalization and store the result
min_value = df.loc[male_smoker_condition, 'totchol_bmi_sum'].min()
max_value = df.loc[male_smoker_condition, 'totchol_bmi_sum'].max()
df.loc[male_smoker_condition, 'normalized_totchol_bmi_male_smoker'] = (df.loc[male_smoker_condition, 'totchol_bmi_sum'] - min_value) / (max_value - min_value)
