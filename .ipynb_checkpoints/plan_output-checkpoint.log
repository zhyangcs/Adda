# Import necessary libraries:
import pandas as pd

# Define the function to normalize glucose levels for diabetic patients
def normalize_glucose_diabetes(glucose, diabetes):
    # Check if the patient has diabetes
    if diabetes == 1:
        # Calculate min-max normalization for glucose levels
        min_glucose = df.loc[df['diabetes'] == 1, 'glucose'].min()
        max_glucose = df.loc[df['diabetes'] == 1, 'glucose'].max()
        return (glucose - min_glucose) / (max_glucose - min_glucose)
    else:
        # Return None for non-diabetic patients
        return None

# Apply the normalization function to the dataframe
df['normalized_glucose_diabetes'] = df.apply(lambda row: normalize_glucose_diabetes(row['glucose'], row['diabetes']), axis=1)
