# Import necessary libraries:
import pandas as pd
from sklearn.preprocessing import MinMaxScaler

# Normalize glucose and heart rate
scaler = MinMaxScaler()
df[['glucose', 'heartrate']] = scaler.fit_transform(df[['glucose', 'heartrate']])

# Define function to calculate cardiovascular health ratio
def calculate_cardiovascular_health_ratio(row):
    interaction_factor = (row['currentsmoker'] * row['cigsperday'] + row['prevalenthyp'] * row['bpmeds']) 
    return (row['glucose'] + row['heartrate']) / (1 + interaction_factor)

# Apply the function to create the new feature
df['cardiovascular_health_ratio'] = df.apply(calculate_cardiovascular_health_ratio, axis=1)
