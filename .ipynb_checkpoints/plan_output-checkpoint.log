# Import necessary libraries:
import pandas as pd
import numpy as np

# Core code definition
def calculate_cardiovascular_risk_score(row):
    # Normalize systolic and diastolic blood pressure
    normalized_sysbp = row['sysbp'] / df['sysbp'].max()
    normalized_diabp = row['diabp'] / df['diabp'].max()

    # Normalize glucose
    normalized_glucose = row['glucose'] / df['glucose'].max()

    # Condition for individuals with diabetes
    diabetes_condition = (row['diabetes'] == 1)
    diabetes_score = (normalized_sysbp + normalized_diabp - normalized_glucose) if diabetes_condition else 0

    # Mean BMI of non-smokers with prevalent hypertension
    mean_bmi_non_smokers_hyp = df[(df['currentsmoker'] == 0) & (df['prevalenthyp'] == 1)]['bmi'].mean()

    # Logarithm of (age + totchol) for male patients who do not have diabetes
    male_no_diabetes_condition = (row['gender'] == 1) & (row['diabetes'] == 0)
    male_score = (mean_bmi_non_smokers_hyp * np.log(row['age'] + row['totchol'])) if male_no_diabetes_condition else 0

    # Adjustment factor: Division by product of mean heart rate and bmi for individuals on blood pressure medication
    adjustment_factor = df[df['bpmeds'] == 1][['heartrate', 'bmi']].mean().prod()

    # Calculate cardiovascular risk score
    return (diabetes_score + male_score) / adjustment_factor if adjustment_factor != 0 else 0

# Apply the function to the DataFrame
df['cardiovascular_risk_score'] = df.apply(calculate_cardiovascular_risk_score, axis=1)
