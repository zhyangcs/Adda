# Import necessary libraries:
import pandas as pd
import numpy as np

# Normalize sysbp and diabp
df['normalized_sysbp'] = (df['sysbp'] - df['sysbp'].min()) / (df['sysbp'].max() - df['sysbp'].min())
df['normalized_diabp'] = (df['diabp'] - df['diabp'].min()) / (df['diabp'].max() - df['diabp'].min())

# Apply gender and age-specific filters using apply function
def calculate_score(row):
    gender_factor = 1.1 if row['gender'] == 1 else 1.0
    age_factor = 1.2 if row['age'] > 50 else 1.0

    # Combine the normalized blood pressure values with heart rate, adjusted by the filters
    score = (0.5 * row['normalized_sysbp'] + 0.5 * row['normalized_diabp']) * row['heartrate'] * gender_factor * age_factor
    return score

# Calculate the blood_pressure_multifactor_score
df['blood_pressure_multifactor_score'] = df.apply(calculate_score, axis=1)
