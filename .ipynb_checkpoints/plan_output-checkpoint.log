# Core code definition
sysbp_mean_overweight = df.loc[df['bmi'] > 25, 'sysbp'].mean()
avg_glucose_women_smokers_no_diabetes = df.loc[(df['gender'] == 0) & (df['currentsmoker'] == 1) & (df['diabetes'] == 0), 'glucose'].mean()
mean_totchol_hypertensive_males = df.loc[(df['gender'] == 1) & ((df['prevalenthyp'] == 1) | (df['bpmeds'] == 1)), 'totchol'].mean()
mean_heartrate_no_stroke = df.loc[df['prevalentstroke'] == 0, 'heartrate'].mean()

cardiometabolic_index = (
    (sysbp_mean_overweight * avg_glucose_women_smokers_no_diabetes) +
    (2 * mean_totchol_hypertensive_males)
) / mean_heartrate_no_stroke

df['cardiometabolic_index'] = cardiometabolic_index
