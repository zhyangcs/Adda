 # Import necessary libraries
import pandas as pd

# Core code definition
def calculate_cardio_metabolic_factor(row):
    cholesterol_adj = row['totchol'] * (1.25 if row['currentsmoker'] == 1 else 1)
    blood_pressure_adj = row['sysbp'] * (1.1 if row['prevalenthyp'] == 1 else 1)
    bmi_adj = row['bmi'] * (1.2 if row['diabetes'] == 1 else 1)
    
    normalized_glucose = (row['glucose'] - df['glucose'].mean()) / df['glucose'].std()
    cardio_metabolic_factor = (cholesterol_adj + blood_pressure_adj + bmi_adj) * normalized_glucose
    
    return cardio_metabolic_factor * (0.95 if row['gender'] == 0 else 1)

